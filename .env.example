# Ambiente de execucao: development (mocks) ou production (implementacoes reais)
APP_ENV=production

# Provider de LLM e embeddings: openai ou gemini
LLM_PROVIDER=openai

# Chave da API da OpenAI (necessaria quando LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Chave da API do Google/Gemini (necessaria quando LLM_PROVIDER=gemini)
GOOGLE_API_KEY=

# String de conexao do PostgreSQL com pgVector (necessaria quando APP_ENV=production)
POSTGRES_CONNECTION_STRING=postgresql+psycopg2://postgres:postgres@localhost:5432/pdf_search

# Parametros de chunking e busca
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
SEARCH_K=10

# Modelos de LLM
OPENAI_LLM_MODEL=gpt-5-nano
GEMINI_LLM_MODEL=gemini-2.5-flash-lite

# Modelos de embeddings
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
